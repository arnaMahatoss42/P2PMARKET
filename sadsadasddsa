<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>P2P Market</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>

<header>
  <h1>P2P Market</h1>
</header>

<section class="cards">
  <div class="card">
    <h3>BTC</h3>
    <p id="btc">$--</p>
  </div>
  <div class="card">
    <h3>ETH</h3>
    <p id="eth">$--</p>
  </div>
  <div class="card">
    <h3>USDT</h3>
    <p id="usdt">$1</p>
  </div>
</section>

<section class="p2p">
  <h2>P2P Offers</h2>
  <table>
    <thead>
      <tr>
        <th>Trader</th>
        <th>Price</th>
        <th>Payment</th>
        <th>Limit</th>
      </tr>
    </thead>
    <tbody id="offers"></tbody>
  </table>
</section>

<script src="script.js"></script>
</body>
</html>

